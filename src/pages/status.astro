---
import BaseLayout from "../layouts/BaseLayout.astro";
const t = {
  zh: { nav_new: "新增分析", nav_status: "任务状态", nav_reports: "报告列表", title_status: "任务状态", subtitle: "任务队列" },
  en: { nav_new: "New Analysis", nav_status: "Task Status", nav_reports: "Reports", title_status: "Task Status", subtitle: "Task Queue" }
};
---
<BaseLayout title="Task Status - Patent Analysis Agent">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="logo">P</div>
      <div class="brand-text">Patent Analysis<small>Agent System</small></div>
    </div>
    <nav class="sidebar-nav">
      <a href="/"><span class="icon">✨</span><span data-key="nav_new">新增分析</span></a>
      <a href="/status" class="active"><span class="icon">📋</span><span data-key="nav_status">任务状态</span></a>
      <a href="/reports"><span class="icon">📊</span><span data-key="nav_reports">报告列表</span></a>
    </nav>
    <div class="sidebar-footer">
      <button class="lang-switch" onclick="toggleLang()"><span id="langFlag">🇹🇼</span><span id="langLabel">EN</span></button>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">
    <div class="page-header">
      <h1 data-key="title_status">任务状态</h1>
    </div>
    <div class="card">
      <div id="loading" style="color:var(--text-muted);padding:1rem 0;">加载中...</div>
      <div id="tasks"></div>
    </div>
  </main>

  <script is:inline>
    const DICT = {
      zh: {
        nav_new: "新增分析", nav_status: "任务状态", nav_reports: "报告列表",
        title_status: "任务状态", loading: "加载中...", empty: "暂无任务", error: "加载失败",
        retry: "重试", table_state: "状态", table_title: "标题", table_created: "创建时间", table_view: "查看",
        badge_pending: "待处理", badge_processing: "处理中", badge_completed: "已完成", badge_failed: "失败",
      },
      en: {
        nav_new: "New Analysis", nav_status: "Task Status", nav_reports: "Reports",
        title_status: "Task Status", loading: "Loading...", empty: "No tasks yet", error: "Failed to load",
        retry: "Retry", table_state: "State", table_title: "Title", table_created: "Created", table_view: "View",
        badge_pending: "Pending", badge_processing: "Processing", badge_completed: "Completed", badge_failed: "Failed",
      }
    };

    let currentLang = localStorage.getItem('patent-lang') || 'zh';

    function applyLanguage() {
      const d = DICT[currentLang];
      document.querySelectorAll('[data-key]').forEach(el => {
        const key = el.getAttribute('data-key');
        if (d[key]) el.textContent = d[key];
      });
      const lf = document.getElementById('langFlag'), ll = document.getElementById('langLabel');
      if (lf) lf.textContent = currentLang === 'zh' ? '🇹🇼' : '🇺🇸';
      if (ll) ll.textContent = currentLang === 'zh' ? 'EN' : '中文';
    }

    function toggleLang() {
      currentLang = currentLang === 'zh' ? 'en' : 'zh';
      localStorage.setItem('patent-lang', currentLang);
      applyLanguage();
      loadTasks();
    }

    function formatDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      return d.toLocaleDateString(currentLang === 'zh' ? 'zh-TW' : 'en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    async function loadTasks() {
      const container = document.getElementById('tasks');
      const loading = document.getElementById('loading');
      const d = DICT[currentLang];
      if (loading) loading.style.display = 'block';
      container.innerHTML = '';

      try {
        const resp = await fetch('/api/list-tasks?state=all');
        const tasks = await resp.json();
        if (loading) loading.style.display = 'none';

        if (tasks.error) {
          container.innerHTML = `<div class="result-msg error">${d.error}: ${tasks.error}</div>`;
          return;
        }
        if (!tasks.length) {
          container.innerHTML = `<p style="color:var(--text-muted);text-align:center;padding:2rem 0;">${d.empty}</p>`;
          return;
        }

        const stateMap = {
          pending: { cls: 'badge-pending', label: d.badge_pending },
          processing: { cls: 'badge-processing', label: d.badge_processing },
          completed: { cls: 'badge-completed', label: d.badge_completed },
          failed: { cls: 'badge-failed', label: d.badge_failed },
        };

        const rows = tasks.map(t => {
          const label = t.labels.find(l => ['pending','processing','completed','failed'].includes(l)) || 'pending';
          const st = stateMap[label] || stateMap.pending;
          return `<tr>
            <td><span class="badge ${st.cls}">${st.label}</span></td>
            <td style="font-weight:500;color:var(--text);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${t.title.replace(/"/g,'&quot;')}">${t.title.replace(/^\[[A-Z]+\]\s*/, '')}</td>
            <td style="color:var(--text-muted);font-size:0.8rem;white-space:nowrap;">${formatDate(t.created_at)}</td>
            <td><a href="${t.url}" target="_blank" style="color:var(--accent);font-size:0.85rem;text-decoration:none;">GitHub →</a></td>
          </tr>`;
        }).join('');

        container.innerHTML = `
          <div style="overflow-x:auto;">
            <table class="data-table">
              <thead><tr>
                <th style="width:90px">${d.table_state}</th>
                <th>${d.table_title}</th>
                <th style="width:130px">${d.table_created}</th>
                <th style="width:80px">${d.table_view}</th>
              </tr></thead>
              <tbody>${rows}</tbody>
            </table>
          </div>`;
      } catch (err) {
        if (loading) loading.style.display = 'none';
        container.innerHTML = `<div class="result-msg error">${d.error}: ${err.message}</div>`;
      }
    }

    applyLanguage();
    loadTasks();
  </script>
</BaseLayout>
