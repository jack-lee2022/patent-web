---
import BaseLayout from "../layouts/BaseLayout.astro";
const t = {
  zh: {
    nav_new: "New Analysis", nav_status: "Task Status", nav_reports: "Reports",
    title_new: "Patent Analysis Request",
    desc_new: "Explore Technology Landscape",
    label_mode: "Analysis Mode", label_topic: "Technology Topic", label_keywords: "Additional Keywords",
    label_invention: "Invention Description", label_field: "Technical Field",
    label_product: "Product Description", label_markets: "Target Markets", label_assignees: "Target Companies",
    label_query: "Search Query", label_patent_ids: "Patent Numbers",
    label_max_results: "Max Results", label_max_structured: "Max Patents",
    placeholder_topic: "Enter technology topic",
    placeholder_keywords: "Add secondary keywords",
    placeholder_invention: "Describe your invention in detail...",
    placeholder_field: "e.g. medical device, sleep therapy",
    placeholder_product: "Describe your product features...",
    placeholder_markets: "US, TW, EP, CN, JP",
    placeholder_assignees: "e.g. Somnics, ResMed, Philips",
    placeholder_query: "e.g. negative pressure therapy sleep apnea",
    placeholder_patent_ids: "WO2019123456, US10/123,456",
    hint_topic: "e.g., Negative Pressure Wound Therapy",
    hint_keywords: "e.g., Oral Device, Mask-Free Nasal",
    hint_markets: "Market codes separated by commas",
    hint_patent_ids: "Patent numbers separated by commas",
    btn_submit: "SUBMIT ANALYSIS REQUEST",
    mode_sota: "State of the Art (SOTA) - Technology Landscape", mode_patentability: "Patentability Assessment", mode_fto: "Freedom to Operate (FTO)", mode_structured: "Structured Analysis",
    subtitle_sota: "Explore the technology landscape and patent distribution in a specific field",
    subtitle_patentability: "Assess novelty, inventiveness, and patentability of an invention",
    subtitle_fto: "Analyze whether a product infringes existing patents",
    subtitle_structured: "Perform deep structured analysis on a single patent",
    scenario_sota_1: "Company entering new market, mapping key players",
    scenario_sota_2: "Investor Due Diligence",
    scenario_sota_3: "R&D team scoping existing technology",
    scenario_patentability_1: "Engineer invented new method, assess novelty",
    scenario_patentability_2: "Prior art search before patent filing",
    scenario_patentability_3: "Patent attorney evaluating invention",
    scenario_fto_1: "Pre-launch patent infringement risk assessment",
    scenario_fto_2: "IP Due Diligence in M&A transactions",
    scenario_fto_3: "Competitive analysis, confirm safe route",
    scenario_structured_1: "Received infringement notice, analyze claims",
    scenario_structured_2: "Patent license negotiation, evaluate value",
    scenario_structured_3: "Preparing invalidation request",
  },
  en: {
    nav_new: "New Analysis", nav_status: "Task Status", nav_reports: "Reports",
    title_new: "Patent Analysis Request",
    desc_new: "Explore Technology Landscape",
    label_mode: "Analysis Mode", label_topic: "Technology Topic", label_keywords: "Additional Keywords",
    label_invention: "Invention Description", label_field: "Technical Field",
    label_product: "Product Description", label_markets: "Target Markets", label_assignees: "Target Companies",
    label_query: "Search Query", label_patent_ids: "Patent Numbers",
    label_max_results: "Max Results", label_max_structured: "Max Patents",
    placeholder_topic: "Enter technology topic",
    placeholder_keywords: "Add secondary keywords",
    placeholder_invention: "Describe your invention in detail...",
    placeholder_field: "e.g. medical device, sleep therapy",
    placeholder_product: "Describe your product features...",
    placeholder_markets: "US, TW, EP, CN, JP",
    placeholder_assignees: "e.g. Somnics, ResMed, Philips",
    placeholder_query: "e.g. negative pressure therapy sleep apnea",
    placeholder_patent_ids: "WO2019123456, US10/123,456",
    hint_topic: "e.g., Negative Pressure Wound Therapy",
    hint_keywords: "e.g., Oral Device, Mask-Free Nasal",
    hint_markets: "Market codes separated by commas",
    hint_patent_ids: "Patent numbers separated by commas",
    btn_submit: "SUBMIT ANALYSIS REQUEST",
    mode_sota: "State of the Art (SOTA) - Technology Landscape", mode_patentability: "Patentability Assessment", mode_fto: "Freedom to Operate (FTO)", mode_structured: "Structured Analysis",
    subtitle_sota: "Explore the technology landscape and patent distribution in a specific field",
    subtitle_patentability: "Assess novelty, inventiveness, and patentability of an invention",
    subtitle_fto: "Analyze whether a product infringes existing patents",
    subtitle_structured: "Perform deep structured analysis on a single patent",
    scenario_sota_1: "Company entering new market, mapping key players",
    scenario_sota_2: "Investor Due Diligence",
    scenario_sota_3: "R&D team scoping existing technology",
    scenario_patentability_1: "Engineer invented new method, assess novelty",
    scenario_patentability_2: "Prior art search before patent filing",
    scenario_patentability_3: "Patent attorney evaluating invention",
    scenario_fto_1: "Pre-launch patent infringement risk assessment",
    scenario_fto_2: "IP Due Diligence in M&A transactions",
    scenario_fto_3: "Competitive analysis, confirm safe route",
    scenario_structured_1: "Received infringement notice, analyze claims",
    scenario_structured_2: "Patent license negotiation, evaluate value",
    scenario_structured_3: "Preparing invalidation request",
  }
};
---
<BaseLayout title="Patent Analysis Agent">
  <!-- Centered Layout -->
  <div class="centered-page">
    <!-- Top Language Toggle -->
    <div class="top-bar">
      <button class="lang-toggle" onclick="toggleLang()">
        <span id="langLabel">EN</span> | <span id="langAlt">中文</span>
      </button>
    </div>

    <!-- Logo & Title -->
    <div class="hero">
      <div class="hero-logo">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2" opacity="0.3"/>
          <path d="M24 8C24 8 32 16 32 24C32 32 24 40 24 40" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M24 12C24 12 28 18 28 24C28 30 24 36 24 36" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
          <path d="M24 16C24 16 26 20 26 24C26 28 24 32 24 32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        </svg>
      </div>
      <h1 class="hero-title">PATENT ANALYSIS AGENT</h1>
    </div>

    <!-- Navigation -->
    <nav class="top-nav">
      <a href="/" class="active" data-key="nav_new">New Analysis</a>
      <a href="/status" data-key="nav_status">Task Status</a>
      <a href="/reports" data-key="nav_reports">Reports</a>
    </nav>

    <!-- Form Card -->
    <div class="form-card">
      <h2 class="form-title" data-key="title_new">Patent Analysis Request</h2>
      <p class="form-subtitle" data-key="desc_new">Explore Technology Landscape</p>

      <form id="analysisForm">
        <!-- Analysis Mode -->
        <div class="form-group">
          <label class="form-label" data-key="label_mode">Analysis Mode</label>
          <input type="hidden" id="mode" name="mode" value="sota" />
          <div class="mode-grid">
            <div class="mode-card active" data-mode="sota" onclick="selectMode('sota')">
              <div class="mode-icon">🌍</div>
              <div class="mode-name" data-key="mode_sota">State of the Art (SOTA)</div>
              <ul class="mode-scenarios">
                <li data-key="scenario_sota_1">Company entering new market</li>
                <li data-key="scenario_sota_2">Investor Due Diligence</li>
                <li data-key="scenario_sota_3">R&D team scoping technology</li>
              </ul>
            </div>
            <div class="mode-card" data-mode="patentability" onclick="selectMode('patentability')">
              <div class="mode-icon">💡</div>
              <div class="mode-name" data-key="mode_patentability">Patentability Assessment</div>
              <ul class="mode-scenarios">
                <li data-key="scenario_patentability_1">Engineer assesses novelty</li>
                <li data-key="scenario_patentability_2">Prior art search</li>
                <li data-key="scenario_patentability_3">Patent attorney evaluation</li>
              </ul>
            </div>
            <div class="mode-card" data-mode="fto" onclick="selectMode('fto')">
              <div class="mode-icon">🛡️</div>
              <div class="mode-name" data-key="mode_fto">Freedom to Operate (FTO)</div>
              <ul class="mode-scenarios">
                <li data-key="scenario_fto_1">Pre-launch risk assessment</li>
                <li data-key="scenario_fto_2">M&A IP Due Diligence</li>
                <li data-key="scenario_fto_3">Competitive analysis</li>
              </ul>
            </div>
            <div class="mode-card" data-mode="structured" onclick="selectMode('structured')">
              <div class="mode-icon">🔍</div>
              <div class="mode-name" data-key="mode_structured">Structured Analysis</div>
              <ul class="mode-scenarios">
                <li data-key="scenario_structured_1">Infringement notice response</li>
                <li data-key="scenario_structured_2">License negotiation</li>
                <li data-key="scenario_structured_3">Invalidation preparation</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Dynamic Fields -->
        <div id="sota-fields" class="field-section">
          <div class="form-group">
            <label class="form-label" data-key="label_topic">Technology Topic</label>
            <div class="input-with-hint">
              <textarea name="topic" class="form-textarea xl" placeholder="" data-placeholder-key="placeholder_topic" required></textarea>
              <span class="input-hint" data-key="hint_topic">e.g., Negative Pressure Wound Therapy</span>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" data-key="label_keywords">Additional Keywords</label>
            <div class="input-with-hint">
              <textarea name="keywords" class="form-textarea lg" placeholder="" data-placeholder-key="placeholder_keywords"></textarea>
              <span class="input-hint" data-key="hint_keywords">e.g., Oral Device, Mask-Free Nasal</span>
            </div>
          </div>
          <div class="form-group narrow">
            <label class="form-label" data-key="label_max_results">Max Results</label>
            <input type="number" name="max_results" class="form-input" value="50" min="1" max="200" />
          </div>
        </div>

        <div id="patentability-fields" class="field-section" style="display:none">
          <div class="form-group">
            <label class="form-label" data-key="label_invention">Invention Description</label>
            <textarea name="invention" class="form-textarea xl" placeholder="" data-placeholder-key="placeholder_invention" required></textarea>
          </div>
          <div class="form-group">
            <label class="form-label" data-key="label_field">Technical Field</label>
            <input type="text" name="field" class="form-input" placeholder="" data-placeholder-key="placeholder_field" />
          </div>
        </div>

        <div id="fto-fields" class="field-section" style="display:none">
          <div class="form-group">
            <label class="form-label" data-key="label_product">Product Description</label>
            <textarea name="product" class="form-textarea xl" placeholder="" data-placeholder-key="placeholder_product" required></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" data-key="label_markets">Target Markets</label>
              <div class="input-with-hint">
                <input type="text" name="markets" class="form-input" placeholder="" data-placeholder-key="placeholder_markets" />
                <span class="input-hint" data-key="hint_markets">Market codes separated by commas</span>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" data-key="label_assignees">Target Companies</label>
              <input type="text" name="assignees" class="form-input" placeholder="" data-placeholder-key="placeholder_assignees" />
            </div>
          </div>
        </div>

        <div id="structured-fields" class="field-section" style="display:none">
          <div class="form-group">
            <label class="form-label" data-key="label_query">Search Query</label>
            <input type="text" name="query" class="form-input" placeholder="" data-placeholder-key="placeholder_query" required />
          </div>
          <div class="form-group">
            <label class="form-label" data-key="label_patent_ids">Patent Numbers</label>
            <div class="input-with-hint">
              <input type="text" name="patent_ids" class="form-input" placeholder="" data-placeholder-key="placeholder_patent_ids" />
              <span class="input-hint" data-key="hint_patent_ids">Patent numbers separated by commas</span>
            </div>
          </div>
          <div class="form-group narrow">
            <label class="form-label" data-key="label_max_structured">Max Patents</label>
            <input type="number" name="max_structured" class="form-input" value="10" min="1" max="50" />
          </div>
        </div>

        <button type="submit" class="btn-submit" id="submitBtn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span data-key="btn_submit">SUBMIT ANALYSIS REQUEST</span>
        </button>

        <div id="result"></div>
      </form>
    </div>
  </div>

  <!-- Sparkle decoration -->
  <div class="sparkle" aria-hidden="true">✦</div>

  <script is:inline define:vars={{ DICT: t }}>
    let currentLang = localStorage.getItem('patent-lang') || 'zh';

    window.applyLanguage = function() {
      const d = DICT[currentLang];
      document.querySelectorAll('[data-key]').forEach(el => {
        const key = el.getAttribute('data-key');
        if (d[key]) el.textContent = d[key];
      });
      document.querySelectorAll('[data-placeholder-key]').forEach(el => {
        const key = el.getAttribute('data-placeholder-key');
        if (d[key]) el.placeholder = d[key];
      });

      const label = document.getElementById('langLabel');
      const alt = document.getElementById('langAlt');
      if (label) label.textContent = currentLang === 'zh' ? 'EN' : '中文';
      if (alt) alt.textContent = currentLang === 'zh' ? '中文' : 'EN';

      document.documentElement.lang = currentLang === 'zh' ? 'zh-TW' : 'en';
    }

    window.toggleLang = function() {
      currentLang = currentLang === 'zh' ? 'en' : 'zh';
      localStorage.setItem('patent-lang', currentLang);
      window.applyLanguage();
    }

    // Mode switching
    const modeInput = document.getElementById('mode');
    const sections = {
      sota: document.getElementById('sota-fields'),
      patentability: document.getElementById('patentability-fields'),
      fto: document.getElementById('fto-fields'),
      structured: document.getElementById('structured-fields')
    };

    window.selectMode = function(mode) {
      modeInput.value = mode;
      document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('active'));
      const card = document.querySelector('.mode-card[data-mode="' + mode + '"]');
      if (card) card.classList.add('active');
      Object.values(sections).forEach(s => { if(s) s.style.display = 'none'; });
      if (sections[mode]) sections[mode].style.display = 'block';
    }

    window.applyLanguage();

    document.getElementById('analysisForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const result = document.getElementById('result');
      btn.disabled = true;
      const originalText = btn.querySelector('span').textContent;
      btn.querySelector('span').textContent = currentLang === 'zh' ? '提交中...' : 'Submitting...';

      try {
        const fd = new FormData(this);
        const payload = { mode: fd.get('mode') };
        const mode = payload.mode;

        if (mode === 'sota') {
          payload.topic = fd.get('topic');
          payload.keywords = fd.get('keywords') || '';
          payload.max_results = parseInt(fd.get('max_results')) || 50;
        } else if (mode === 'patentability') {
          payload.invention = fd.get('invention');
          payload.field = fd.get('field') || '';
        } else if (mode === 'fto') {
          payload.product = fd.get('product');
          payload.markets = fd.get('markets') || '';
          payload.assignees = fd.get('assignees') || '';
        } else if (mode === 'structured') {
          payload.query = fd.get('query');
          payload.patent_ids = fd.get('patent_ids') || '';
          payload.max_structured = parseInt(fd.get('max_structured')) || 10;
        }

        const resp = await fetch('/api/create-task', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await resp.json();
        if (resp.ok) {
          result.innerHTML = '<div class="result success">' + (currentLang === 'zh' ? '任务已创建！' : 'Task created!') + ' <a href="' + data.issue_url + '" target="_blank">GitHub #' + data.issue_number + '</a></div>';
          setTimeout(() => { window.location.href = '/status'; }, 1500);
        } else {
          result.innerHTML = '<div class="result error">' + (data.error || 'Error') + '</div>';
        }
      } catch (err) {
        result.innerHTML = '<div class="result error">' + err.message + '</div>';
      } finally {
        btn.disabled = false;
        btn.querySelector('span').textContent = originalText;
      }
    });
  </script>
</BaseLayout>
